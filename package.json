{
  "name": "tiny-fs-access",
  "version": "1.2.0",
  "description": "A modern, lightweight, Promise-based TypeScript wrapper for the native File System Access API.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.mjs",
      "require": "./dist/vue.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "file-system",
    "fs",
    "fs-access",
    "browser",
    "file",
    "promise"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qxie11/tiny-fs-access.git"
  },
  "bugs": {
    "url": "https://github.com/qxie11/tiny-fs-access/issues"
  },
  "homepage": "https://github.com/qxie11/tiny-fs-access#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vue": "^3.5.40"
  }
}
